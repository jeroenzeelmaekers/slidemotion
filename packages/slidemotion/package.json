{
  "name": "slidemotion",
  "version": "0.1.0",
  "type": "module",
  "description": "A React framework for building animated slide decks in JSX, optimized for presenting code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeroenzeelmaekers/slidemotion.git",
    "directory": "packages/slidemotion"
  },
  "homepage": "https://github.com/jeroenzeelmaekers/slidemotion#readme",
  "bugs": {
    "url": "https://github.com/jeroenzeelmaekers/slidemotion/issues"
  },
  "keywords": [
    "react",
    "slides",
    "presentation",
    "animation",
    "code",
    "shiki",
    "jsx",
    "deck"
  ],
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "default": "./dist/theme/index.js"
    },
    "./animation": {
      "types": "./dist/animation/index.d.ts",
      "import": "./dist/animation/index.js",
      "default": "./dist/animation/index.js"
    },
    "./code": {
      "types": "./dist/code/index.d.ts",
      "import": "./dist/code/index.js",
      "default": "./dist/code/index.js"
    },
    "./presenter": {
      "types": "./dist/presenter/index.d.ts",
      "import": "./dist/presenter/index.js",
      "default": "./dist/presenter/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "shiki": "^4.0.1",
    "shiki-magic-move": "^1.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
