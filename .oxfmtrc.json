{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "proseWrap": "preserve",
  "ignorePatterns": [
    "node_modules/**",
    "**/node_modules/**",
    "dist/**",
    "**/dist/**",
    "coverage/**",
    "**/coverage/**",
    ".astro/**",
    "**/.astro/**",
    "bun.lock",
    "**/*.d.ts",
    "**/*.gen.*",
    "**/*.generated.*",
    "*.tsbuildinfo"
  ]
}
