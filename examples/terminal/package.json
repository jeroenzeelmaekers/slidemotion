{
  "name": "example-terminal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "format": "oxfmt -c ../../.oxfmtrc.json \"src/**/*.{ts,tsx,js,jsx,mjs,cjs}\" \"vite.config.ts\"",
    "format:check": "oxfmt --check -c ../../.oxfmtrc.json \"src/**/*.{ts,tsx,js,jsx,mjs,cjs}\" \"vite.config.ts\"",
    "lint": "oxlint -c ../../.oxlintrc.json .",
    "lint:fix": "oxlint --fix -c ../../.oxlintrc.json .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "slidemotion": "workspace:*"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.54.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
