---
import type { LinkItem } from "../../data/marketing";

interface Props {
  cta: LinkItem;
  links: LinkItem[];
}

const { cta, links } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-[var(--border)]/80 bg-[var(--bg)]/85 backdrop-blur-xl">
  <div class="mx-auto flex max-w-[1440px] flex-col gap-4 px-6 py-4 sm:px-10 md:flex-row md:items-center md:justify-between lg:px-16">
    <a href="/" class="font-mono-ui text-[13px] font-semibold tracking-[0.28em] text-[var(--text)] uppercase">
      slidemotion
    </a>

    <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-[var(--muted)] md:flex-1 md:justify-center md:gap-7">
      {links.map((link) => (
        <a class="transition-colors duration-200 hover:text-[var(--text)]" href={link.href}>
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href={cta.href}
      class="inline-flex items-center gap-2 self-center rounded-[10px] border border-[var(--border)] bg-[var(--surface)] px-4 py-2 text-sm font-semibold text-[var(--text)] transition-transform duration-200 hover:-translate-y-0.5 md:self-auto"
    >
      {cta.label}
      <span class="font-mono-ui text-[12px] text-[var(--accent)]">-&gt;</span>
    </a>
  </div>
</header>
