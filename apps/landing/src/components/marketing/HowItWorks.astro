---
import type { StepCard } from "../../data/marketing";

interface Props {
  eyebrow: string;
  steps: StepCard[];
  title: string;
}

const { eyebrow, steps, title } = Astro.props;
---

<section class="border-b border-[var(--border)]" id="workflow">
  <div class="mx-auto max-w-[1440px] px-6 py-20 sm:px-10 lg:px-16">
    <div class="text-center">
      <p class="text-[11px] font-semibold tracking-[0.3em] text-[var(--accent-strong)] uppercase">{eyebrow}</p>
      <h2 class="mt-4 text-balance text-4xl font-semibold tracking-[-0.05em] text-[var(--text)] sm:text-[2.5rem]">
        {title}
      </h2>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {steps.map((step, index) => (
        <article class="flex h-full flex-col items-center rounded-[22px] border border-[var(--border)] bg-[var(--surface)] px-7 py-8 text-center">
          <div class={`flex h-11 w-11 items-center justify-center rounded-full border text-sm font-semibold ${index === 0 ? "border-[var(--accent)] bg-[var(--accent)] text-[var(--accent-contrast)]" : "border-cyan-500/60 text-cyan-500 dark:text-cyan-300"}`}>
            {index + 1}
          </div>
          <h3 class="mt-5 text-xl font-semibold text-[var(--text)]">{step.title}</h3>
          <div class="mt-5 w-full rounded-[12px] border border-[var(--border)] bg-[var(--panel)] px-4 py-3 font-mono-ui text-[12px] text-[var(--muted)]">
            {step.command}
          </div>
          <p class="mt-5 text-sm leading-7 text-[var(--muted)]">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
