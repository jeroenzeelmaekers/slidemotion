---
import type { FooterColumn } from "../../data/marketing";

interface Props {
  columns: FooterColumn[];
  tagline: string;
}

const { columns, tagline } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)]">
  <div class="mx-auto max-w-[1440px] px-6 py-12 sm:px-10 lg:px-16">
    <div class="flex flex-col gap-10 lg:flex-row lg:justify-between">
      <div class="max-w-[320px]">
        <p class="font-mono-ui text-[13px] font-semibold tracking-[0.28em] text-[var(--text)] uppercase">slidemotion</p>
        <p class="mt-4 text-sm leading-7 text-[var(--muted)]">{tagline}</p>
      </div>

      <div class="grid gap-8 sm:grid-cols-3">
        {columns.map((column) => (
          <div>
            <p class="text-[11px] font-semibold tracking-[0.26em] text-[var(--subtle)] uppercase">{column.title}</p>
            <ul class="mt-4 space-y-3 text-sm text-[var(--muted)]">
              {column.links.map((link) => (
                <li>
                  <a class="transition-colors duration-200 hover:text-[var(--text)]" href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-[var(--border)] pt-6 text-xs text-[var(--subtle)] sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} slidemotion.</p>
      <p>Built with Astro, Tailwind, and live npm stats.</p>
    </div>
  </div>
</footer>
