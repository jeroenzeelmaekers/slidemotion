---
interface Props {
  items: string[];
  label: string;
}

const { items, label } = Astro.props;
---

<section class="border-b border-t border-[var(--border)]/90">
  <div class="mx-auto flex max-w-[1440px] flex-col items-center gap-5 px-6 py-8 text-center sm:px-10 lg:flex-row lg:justify-center lg:px-16 lg:text-left">
    <span class="text-[11px] font-semibold tracking-[0.28em] text-[var(--subtle)] uppercase">{label}</span>
    <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-[var(--muted)] lg:gap-4">
      {items.map((item) => (
        <span class="rounded-full border border-[var(--border)] bg-[var(--surface)] px-4 py-2">{item}</span>
      ))}
    </div>
  </div>
</section>
