---
import type { FeatureCard } from "../../data/marketing";

interface Props {
  cards: FeatureCard[];
  eyebrow: string;
  title: string;
}

const { cards, eyebrow, title } = Astro.props;
---

<section class="border-b border-[var(--border)] bg-[var(--surface)]/65">
  <div class="mx-auto max-w-[1440px] px-6 py-20 sm:px-10 lg:px-16">
    <div class="max-w-[640px]">
      <p class="text-[11px] font-semibold tracking-[0.3em] text-[var(--accent-strong)] uppercase">{eyebrow}</p>
      <h2 class="mt-4 text-balance text-4xl font-semibold tracking-[-0.05em] text-[var(--text)] sm:text-[2.5rem]">
        {title}
      </h2>
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded-[22px] border border-[var(--border)] bg-[var(--border)] lg:grid-cols-3">
      {cards.map((card) => (
        <article class="h-full bg-[var(--bg)] p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-[var(--accent-soft)] font-mono-ui text-[13px] font-semibold text-[var(--accent)]">
            {card.icon}
          </div>
          <h3 class="mt-5 text-lg font-semibold text-[var(--text)]">{card.title}</h3>
          <p class="mt-3 text-sm leading-7 text-[var(--muted)]">{card.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
