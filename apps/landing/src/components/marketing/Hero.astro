---
import type { LinkItem } from "../../data/marketing";

interface Props {
  description: string;
  latestVersion: string;
  primaryCta: LinkItem;
  secondaryCta: LinkItem;
  title: string;
}

const { description, latestVersion, primaryCta, secondaryCta, title } = Astro.props;
---

<section class="relative overflow-hidden border-b border-[var(--border)]" id="top">
  <div class="pointer-events-none absolute left-[max(1.5rem,calc(50%-34rem))] top-14 z-0 h-56 w-56 rounded-full bg-[var(--glow-left)] blur-3xl sm:h-64 sm:w-64 lg:left-[max(2rem,calc(50%-35rem))] lg:top-18"></div>
  <div class="pointer-events-none absolute bottom-[-3rem] right-[max(1.5rem,calc(50%-34rem))] z-0 h-56 w-56 rounded-full bg-[var(--glow-right)] blur-3xl sm:h-64 sm:w-64 lg:right-[max(2rem,calc(50%-35rem))] lg:bottom-[-2rem]"></div>

  <div class="relative z-10 mx-auto flex max-w-[1440px] flex-col items-center px-6 pb-20 pt-20 text-center sm:px-10 lg:px-16 lg:pb-24 lg:pt-24">
    <div class="inline-flex items-center gap-3 rounded-full border border-[var(--border)] bg-[var(--accent-soft)] px-4 py-2 text-[11px] font-semibold tracking-[0.28em] text-[var(--accent-strong)] uppercase">
      <span class="h-2 w-2 rounded-full bg-[var(--accent)]"></span>
      <span>npm v{latestVersion}</span>
      <span class="text-[var(--subtle)]">live now</span>
    </div>

    <div class="mt-8 max-w-[860px] space-y-6">
      <h1 class="text-balance text-[2.9rem] font-semibold leading-[0.96] tracking-[-0.06em] text-[var(--text)] sm:text-[4rem] lg:text-[4.8rem]">
        {title}
      </h1>
      <p class="mx-auto max-w-[720px] text-pretty text-[1.05rem] leading-8 text-[var(--muted)] sm:text-[1.15rem]">
        {description}
      </p>
    </div>

    <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row">
      <a
        href={primaryCta.href}
        class="inline-flex min-w-[190px] items-center justify-center rounded-[10px] bg-[var(--accent)] px-6 py-3.5 text-sm font-semibold text-[var(--accent-contrast)] transition-transform duration-200 hover:-translate-y-0.5"
      >
        {primaryCta.label}
      </a>
      <a
        href={secondaryCta.href}
        class="inline-flex min-w-[190px] items-center justify-center rounded-[10px] border border-[var(--border)] px-6 py-3.5 text-sm font-semibold text-[var(--text)] transition-colors duration-200 hover:bg-[var(--surface)]"
      >
        {secondaryCta.label}
      </a>
    </div>

    <div class="mt-12 w-full max-w-[880px] overflow-hidden rounded-[20px] border border-[var(--border)] bg-[var(--surface)] text-left shadow-[0_24px_80px_-40px_var(--glow-left)]">
      <div class="flex items-center justify-between border-b border-[var(--border)] px-5 py-4">
        <div class="flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--accent)]"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--subtle)]/60"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--glow-right)]"></span>
        </div>
        <span class="font-mono-ui text-[12px] uppercase tracking-[0.24em] text-[var(--subtle)]">deck.tsx</span>
      </div>

      <div class="grid gap-0 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="border-b border-[var(--border)] bg-[var(--panel)] p-6 lg:border-b-0 lg:border-r">
          <pre class="overflow-x-auto font-mono-ui text-[13px] leading-7 text-[var(--muted)]"><code><span class="text-[var(--accent)]">import</span> &#123; Presentation, Presenter, Slide &#125; <span class="text-[var(--accent)]">from</span> <span class="text-[var(--text)]">"slidemotion"</span>;

<span class="text-[var(--accent)]">export default function</span> <span class="text-[var(--text)]">Talk</span>() &#123;
  <span class="text-[var(--accent)]">return</span> (
    &lt;<span class="text-[var(--text)]">Presentation</span>&gt;
      &lt;<span class="text-[var(--text)]">Presenter</span>&gt;
        &lt;<span class="text-[var(--text)]">Slide</span> className=<span class="text-[var(--text)]">"hero"</span>&gt;
          Build demos <span class="text-[var(--accent)]">that move</span>
        &lt;/<span class="text-[var(--text)]">Slide</span>&gt;
      &lt;/<span class="text-[var(--text)]">Presenter</span>&gt;
    &lt;/<span class="text-[var(--text)]">Presentation</span>&gt;
  );
&#125;</code></pre>
        </div>

        <div class="space-y-4 p-6">
          <div class="rounded-[16px] border border-[var(--border)] bg-[var(--panel)] p-4">
            <div class="flex items-center justify-between text-[11px] uppercase tracking-[0.24em] text-[var(--subtle)]">
              <span>timeline</span>
              <span class="font-mono-ui">step 02</span>
            </div>
            <div class="mt-4 space-y-3">
              <div class="flex items-center gap-3">
                <span class="w-14 font-mono-ui text-[12px] text-[var(--subtle)]">00:00</span>
                <div class="h-2 flex-1 rounded-full bg-[var(--surface-2)]">
                  <div class="h-2 w-[32%] rounded-full bg-[var(--accent)]"></div>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class="w-14 font-mono-ui text-[12px] text-[var(--subtle)]">00:18</span>
                <div class="h-2 flex-1 rounded-full bg-[var(--surface-2)]">
                  <div class="h-2 w-[56%] rounded-full bg-cyan-500/70"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="rounded-[16px] border border-[var(--border)] bg-[var(--panel)] p-4">
            <div class="flex items-center justify-between">
              <span class="text-sm font-semibold text-[var(--text)]">Code, notes, terminal</span>
              <span class="font-mono-ui text-[12px] text-[var(--accent)]">synced</span>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <div class="rounded-[12px] border border-[var(--border)] bg-[var(--surface)] p-3 text-xs text-[var(--muted)]">Morph code across steps</div>
              <div class="rounded-[12px] border border-[var(--border)] bg-[var(--surface)] p-3 text-xs text-[var(--muted)]">Keep speaker notes nearby</div>
              <div class="rounded-[12px] border border-[var(--border)] bg-[var(--surface)] p-3 text-xs text-[var(--muted)]">Replay terminal output cleanly</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
